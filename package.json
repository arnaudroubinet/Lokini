{
  "name": "lokini",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @lokini/web dev",
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @lokini/core build",
    "build:web": "pnpm --filter @lokini/web build",
    "test": "pnpm -r test",
    "test:core": "pnpm --filter @lokini/core test",
    "test:web": "pnpm --filter @lokini/web test",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json,css}\"",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-security": "^4.0.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
